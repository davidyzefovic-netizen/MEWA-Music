rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Catch-all Safety Net: Deny everything by default
    match /{document=**} {
      allow read, write: if false;
    }

    // --- REUSABLE SECURITY PRIMITIVES ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Bootstrapped Admin check (checks both email from metadata and db role)
    function isAdmin() {
      return isSignedIn() && (
        ((request.auth.token.email == "davidyzefovic@gmail.com" || request.auth.token.email == "maksimumatov228@gmail.com") && request.auth.token.email_verified == true) || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin")
      );
    }

    // Author check
    function isAuthor() {
      return isSignedIn() && (
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "author") ||
        isAdmin()
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- SCHEMAS VALIDATION HELPERS ---

    function isValidUser(data) {
      return data.uid is string && data.uid.size() <= 128 &&
             data.email is string && data.email.size() <= 128 &&
             data.role is string && (data.role == "user" || data.role == "author" || data.role == "admin") &&
             (!('preferredGenres' in data) || data.preferredGenres is list);
    }

    function isValidSong(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.title is string && data.title.size() <= 200 &&
             data.artist is string && data.artist.size() <= 200 &&
             (!('album' in data) || data.album is string) &&
             data.lyrics is string && data.lyrics.size() <= 10000 &&
             (!('audioUrl' in data) || data.audioUrl is string) &&
             (!('coverUrl' in data) || data.coverUrl is string) &&
             (!('genres' in data) || data.genres is list) &&
             (!('tags' in data) || data.tags is list) &&
             data.uploadedBy is string && data.uploadedBy.size() <= 128 &&
             (!('authorName' in data) || data.authorName is string) &&
             data.status is string && (data.status == "pending" || data.status == "approved" || data.status == "rejected");
    }

    function isValidPlaylist(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.name is string && data.name.size() <= 128 &&
             data.ownerId == request.auth.uid &&
             data.songIds is list &&
             (!('isPrivate' in data) || data.isPrivate is bool);
    }

    function isValidFavorite(data) {
      return data.userId == request.auth.uid &&
             data.songId is string && data.songId.size() <= 128;
    }

    function isValidHistory(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.userId == request.auth.uid &&
             data.songId is string && data.songId.size() <= 128;
    }

    function isValidComplaint(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.songId is string && data.songId.size() <= 128 &&
             data.reporterId == request.auth.uid &&
             data.reason is string && data.reason.size() <= 200 &&
             data.description is string && data.description.size() <= 2000 &&
             data.status is string && (data.status == "pending" || data.status == "resolved" || data.status == "dismissed");
    }

    function isValidNotification(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.userId is string && data.userId.size() <= 128 &&
             data.title is string && data.title.size() <= 128 &&
             data.message is string && data.message.size() <= 1000 &&
             data.read is bool;
    }

    
    function isValidBanner(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.title is string && data.title.size() <= 200 &&
             data.imageUrl is string &&
             (!('link' in data) || data.link is string) &&
             data.createdBy is string && data.createdBy.size() <= 128;
    }
\n    function isValidArtist(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.name is string && data.name.size() <= 200 &&
             (!('bio' in data) || data.bio is string) &&
             (!('imageUrl' in data) || data.imageUrl is string) &&
             (!('bannerUrl' in data) || data.bannerUrl is string) &&
             (!('hometown' in data) || data.hometown is string) &&
             (!('formedIn' in data) || data.formedIn is string) &&
             data.createdBy is string && data.createdBy.size() <= 128;
    }

    function isValidAlbum(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.title is string && data.title.size() <= 200 &&
             data.artistId is string && data.artistId.size() <= 128 &&
             data.artistName is string && data.artistName.size() <= 200 &&
             (!('coverUrl' in data) || data.coverUrl is string) &&
             (!('bannerUrl' in data) || data.bannerUrl is string) &&
             (!('behindTheScenes' in data) || data.behindTheScenes is string) &&
             (!('releaseYear' in data) || data.releaseYear is string) &&
             data.createdBy is string && data.createdBy.size() <= 128;
    }


    // --- COLLECTIONS MATCH BLOCKS ---

    // USERS COLLECTION
    match /users/{userId} {
      allow read: if isSignedIn(); // Users can view other user profiles (for author lists), but PII is safe (no private details stored)
      
      // User creation: Can register their profile with default "user" role (or "admin" if email is the bootstrapped admin email)
      allow create: if isSignedIn() && isOwner(userId) && isValidUser(incoming()) && (
        (incoming().role == "user") || 
        (incoming().role == "admin" && (request.auth.token.email == "davidyzefovic@gmail.com" || request.auth.token.email == "maksimumatov228@gmail.com") && request.auth.token.email_verified == true)
      );

      // User update: Regular users cannot modify their own roles (prevents privilege escalation)
      allow update: if isSignedIn() && (
        (isOwner(userId) && isValidUser(incoming()) && incoming().role == existing().role && incoming().uid == existing().uid &&
         incoming().diff(existing()).affectedKeys().hasOnly(['preferredGenres', 'displayName', 'photoURL'])) ||
        isAdmin()
      );

      allow delete: if isAdmin();
      
      // Subcollection for Favorites
      match /favorites/{songId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && isValidId(songId) && isValidFavorite(incoming());
        allow update: if isOwner(userId) && isValidId(songId) && isValidFavorite(incoming());
        allow delete: if isOwner(userId) || isAdmin();
      }
    }

    // SONGS COLLECTION
    match /songs/{songId} {
      // Anyone can read approved songs, but authors and admins can see pending/rejected songs too
      allow read: if (resource != null && resource.data.status == "approved") || (isSignedIn() && (isAuthor() || isAdmin()));
      
      // Creating a song:
      // Author or Admin can upload a song. Authors can only set status to 'pending'
      allow create: if isSignedIn() && isValidId(songId) && isValidSong(incoming()) && (
        (isAuthor() && incoming().uploadedBy == request.auth.uid && incoming().status == "pending") ||
        isAdmin()
      );

      // Editing a song:
      // 1. Authors can edit their own song if they uploaded it, but CANNOT change the status field or the uploadedBy field
      // 2. Admins can edit anything
      allow update: if isSignedIn() && isValidId(songId) && (
        isAdmin() ||
        (isAuthor() && existing().uploadedBy == request.auth.uid && isValidSong(incoming()) &&
         incoming().uploadedBy == existing().uploadedBy &&
         incoming().diff(existing()).affectedKeys().hasOnly(['title', 'artist', 'album', 'lyrics', 'audioUrl', 'coverUrl', 'genres', 'tags', 'authorName'])
        ) ||
        // User incrementing views or likes
        (isValidSong(incoming()) && 
         incoming().diff(existing()).affectedKeys().hasAny(['listensCount', 'likesCount']) &&
         incoming().title == existing().title && incoming().lyrics == existing().lyrics)
      );

      allow delete: if isAdmin() || (isAuthor() && existing().uploadedBy == request.auth.uid);
    }

    // PLAYLISTS COLLECTION
    match /playlists/{playlistId} {
      allow read: if isSignedIn() && (!existing().isPrivate || existing().ownerId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isValidId(playlistId) && isValidPlaylist(incoming()) && incoming().ownerId == request.auth.uid;
      allow update: if isSignedIn() && isValidId(playlistId) && existing().ownerId == request.auth.uid && isValidPlaylist(incoming());
      allow delete: if isSignedIn() && (existing().ownerId == request.auth.uid || isAdmin());
    }

    // LISTENING HISTORY COLLECTION
    match /listeningHistory/{historyId} {
      // Secure list query enforcement: Users can only query their own history
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isValidId(historyId) && isValidHistory(incoming()) && incoming().userId == request.auth.uid;
      allow delete: if isSignedIn() && (existing().userId == request.auth.uid || isAdmin());
    }

    // COMPLAINTS COLLECTION (DMCA/reports)
    match /complaints/{complaintId} {
      // Only reporter and admins can read complaints
      allow read: if isSignedIn() && (resource.data.reporterId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isValidId(complaintId) && isValidComplaint(incoming()) && incoming().reporterId == request.auth.uid && incoming().status == "pending";
      
      // Only admins can modify complaint status
      allow update: if isAdmin() && isValidComplaint(incoming());
      allow delete: if isAdmin();
    }

    // NOTIFICATIONS COLLECTION
    match /notifications/{notificationId} {
      // Only target user and admins can read notifications
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAdmin() && isValidId(notificationId) && isValidNotification(incoming());
      
      // Users can mark notifications as read
      allow update: if isSignedIn() && existing().userId == request.auth.uid && isValidNotification(incoming()) &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['read']);
      allow delete: if isSignedIn() && (existing().userId == request.auth.uid || isAdmin());
    }

    // ARTISTS COLLECTION
    match /artists/{artistId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidId(artistId) && isValidArtist(incoming()) && incoming().createdBy == request.auth.uid;
      allow update: if isSignedIn() && isValidId(artistId) && isValidArtist(incoming()) && (
        existing().createdBy == request.auth.uid || isAdmin() ||
        // Anyone can update views
        incoming().diff(existing()).affectedKeys().hasOnly(['views'])
      );
      allow delete: if isAdmin() || (isSignedIn() && existing().createdBy == request.auth.uid);
    }

    
    // BANNERS COLLECTION
    match /banners/{bannerId} {
      allow read: if true;
      allow create: if isAdmin() && isValidId(bannerId) && isValidBanner(incoming()) && incoming().createdBy == request.auth.uid;
      allow update: if isAdmin() && isValidId(bannerId) && isValidBanner(incoming());
      allow delete: if isAdmin();
    }
\n    // ALBUMS COLLECTION
    match /albums/{albumId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidId(albumId) && isValidAlbum(incoming()) && incoming().createdBy == request.auth.uid;
      allow update: if isSignedIn() && isValidId(albumId) && isValidAlbum(incoming()) && (
        existing().createdBy == request.auth.uid || isAdmin()
      );
      allow delete: if isAdmin() || (isSignedIn() && existing().createdBy == request.auth.uid);
    }
  }
}
