{
  "entities": {
    "user": {
      "title": "User",
      "description": "User profile document containing roles and genre preferences",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique identifier for the user" },
        "email": { "type": "string", "description": "Email address of the user" },
        "displayName": { "type": "string", "description": "Display name of the user" },
        "photoURL": { "type": "string", "description": "Avatar URL of the user" },
        "role": { "type": "string", "enum": ["user", "author", "admin"], "description": "User role: user, author, or admin" },
        "preferredGenres": { "type": "array", "description": "Preferred genres for recommendations" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Account creation timestamp" }
      },
      "required": ["uid", "email", "role"]
    },
    "song": {
      "title": "Song",
      "description": "A musical track containing lyrics, metadata, and play indicators",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique song ID" },
        "title": { "type": "string", "description": "Title of the song" },
        "artist": { "type": "string", "description": "Artist or performer name" },
        "album": { "type": "string", "description": "Album title containing the song" },
        "lyrics": { "type": "string", "description": "Full text lyrics of the song" },
        "audioUrl": { "type": "string", "description": "Streaming audio URL" },
        "coverUrl": { "type": "string", "description": "Cover art image URL" },
        "genres": { "type": "array", "description": "Genres associated with this song" },
        "tags": { "type": "array", "description": "Search tags and keywords" },
        "uploadedBy": { "type": "string", "description": "User UID who uploaded the song" },
        "authorName": { "type": "string", "description": "Display name of the creator" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"], "description": "Approval status for administration" },
        "listensCount": { "type": "integer", "description": "Total plays count" },
        "likesCount": { "type": "integer", "description": "Total users who favorited this track" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Upload timestamp" }
      },
      "required": ["id", "title", "artist", "lyrics", "uploadedBy", "status"]
    },
    "playlist": {
      "title": "Playlist",
      "description": "User-curated list of tracks",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique playlist ID" },
        "name": { "type": "string", "description": "Name of the playlist" },
        "ownerId": { "type": "string", "description": "User ID of the playlist creator" },
        "songIds": { "type": "array", "description": "List of song IDs in this playlist" },
        "isPrivate": { "type": "boolean", "description": "Whether the playlist is private or public" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Playlist creation timestamp" }
      },
      "required": ["id", "name", "ownerId", "songIds"]
    },
    "favorite": {
      "title": "Favorite",
      "description": "User's favorited song entry mapping",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "User UID" },
        "songId": { "type": "string", "description": "Song ID" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Favorited timestamp" }
      },
      "required": ["userId", "songId"]
    },
    "history": {
      "title": "Listening History",
      "description": "A playback event log representing a user listening to a track",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Event log ID" },
        "userId": { "type": "string", "description": "User UID who played the track" },
        "songId": { "type": "string", "description": "Song ID played" },
        "playedAt": { "type": "string", "format": "date-time", "description": "Timestamp of the playback" }
      },
      "required": ["id", "userId", "songId", "playedAt"]
    },
    "complaint": {
      "title": "Complaint",
      "description": "Copyright infringement or content report ticket",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Complaint ID" },
        "songId": { "type": "string", "description": "Target song ID" },
        "songTitle": { "type": "string", "description": "Target song title" },
        "songArtist": { "type": "string", "description": "Target song artist name" },
        "reporterId": { "type": "string", "description": "UID of the reporting user" },
        "reporterEmail": { "type": "string", "description": "Email of the reporting user" },
        "reason": { "type": "string", "description": "Reason category" },
        "description": { "type": "string", "description": "Detailed explanation of the complaint" },
        "status": { "type": "string", "enum": ["pending", "resolved", "dismissed"], "description": "Resolution status" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Timestamp of filing" }
      },
      "required": ["id", "songId", "reporterId", "reason", "description", "status"]
    },
    "notification": {
      "title": "Notification",
      "description": "System or subscription notification about new song releases",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Notification ID" },
        "userId": { "type": "string", "description": "Recipient user UID" },
        "title": { "type": "string", "description": "Header title of the notification" },
        "message": { "type": "string", "description": "Content body text" },
        "read": { "type": "boolean", "description": "Whether the notification has been marked read" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Generation timestamp" }
      },
      "required": ["id", "userId", "title", "message", "read", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "user",
      "description": "Stores core profile settings and preferences for all registered accounts"
    },
    "songs/{songId}": {
      "schema": "song",
      "description": "Stores track details, tags, uploaders, approval status, and lyrics text"
    },
    "playlists/{playlistId}": {
      "schema": "playlist",
      "description": "Stores user curated audio tracks and offline sync markers"
    },
    "users/{userId}/favorites/{songId}": {
      "schema": "favorite",
      "description": "Stores user bookmarks mapping to favorited tracks"
    },
    "listeningHistory/{historyId}": {
      "schema": "history",
      "description": "Stores playback tracking events representing recently played tracks"
    },
    "complaints/{complaintId}": {
      "schema": "complaint",
      "description": "Stores DMCA takedown requests and content reports"
    },
    "notifications/{notificationId}": {
      "schema": "notification",
      "description": "Stores user notifications about artist releases and platform events"
    }
  }
}
